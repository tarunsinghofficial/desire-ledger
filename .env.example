# Clerk (auth for any user) — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
# Phone/LAN testing: set to your computer Wi‑Fi address, e.g. http://192.168.1.10:3000
# Also add that same URL in Clerk Dashboard → Configure → Domains / Redirect URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase Free (cloud sync via /api/sync)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI — enable exactly one provider with true/false
USE_GROQ=true
USE_GEMINI=false

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
